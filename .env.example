NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://rubcube:rubcube@localhost:5432/rubcube?schema=public

# Authentication
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1h
BCRYPT_SALT_ROUNDS=10

# External provider (Rest Countries)
# Rest Countries v5 requires a free API key (https://restcountries.com -> sign up).
# Leave COUNTRIES_API_KEY empty to serve the bundled country snapshot offline.
COUNTRIES_API_URL=https://restcountries.com/v5
COUNTRIES_API_KEY=
COUNTRIES_CACHE_TTL_MS=600000
